{
  "ReverseProxy": {
    "Routes": {
      "identity-route": {
        "ClusterId": "identity-cluster",
        "Match": {
          "Path": "api/identity/{**catch-all}"
        },
        "Transforms": [
          {
            "PathRemovePrefix": "api/identity"
          },
          {
            "PathPrefix": "/api"
          }
        ]
      },
      "product-route": {
        "ClusterId": "product-cluster",
        "Match": {
          "Path": "api/v1/product/{**catch-all}"
        },
        "Transforms": [
          {
            "PathRemovePrefix": "api/v1/product"
          },
          {
            "PathPrefix": "/api/v1"
          }
        ]
      }
    },
    "Clusters": {
      "identity-cluster": {
        "Destinations": {
          "https": {
            "Address": "https://localhost:7092/"
          }
        }
      },
      "product-cluster": {
        "Destinations": {
          "product-instance-1": { "Address": "https://localhost:7002/" },
          "product-instance-2": { "Address": "https://localhost:7003/" },
          "product-instance-3": { "Address": "https://localhost:7004/" }
        }
      }
    }
  }
}
